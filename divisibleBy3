#include<stdio.h>
int main () {
    int num;
    printf("Enter a number : ");
    scanf("%d",&num);
    if(num >99 && num <1000) {
        printf("\nThe number is a 3 digit number");
        if(num%3 == 0) {
            printf("\nThe number is divisible by 3");
        }
        else {
            printf("\nThe number is not divisible by 3");
        }
    }
    else {
        printf("\nThe number is not a 3 digit number");
    }
    return 0;
}
